# Generated at runtime by the optimization layer (never commit)
CLAUDE.md
AGENTS.md
RTK.md
.github/copilot-instructions.md
.claude/
.claudeignore
.copilotignore

# Secrets
.env
.mcp.json

# Logs
*.log

# Runtime backups
*.bak

# Dependencies and caches
node_modules/
__pycache__/
.tokensave/

# Python packaging artifacts
build/
dist/
*.egg-info/

# The vendored copilot-api ships its prebuilt bundle on purpose: llm_cli
# deploys it as-is, so a clone needs no Node build toolchain. Regenerate it
# with `npm run build` in that directory and commit the result.
!llm_cli/vendor/copilot-api/dist/
!llm_cli/vendor/copilot-api/dist/**
